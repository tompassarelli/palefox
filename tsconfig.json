{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,

    // Bundler mode — bun build does the actual emit.
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Strict but pragmatic. noImplicitAny is OFF for now so the legacy
    // src/tabs/index.ts doesn't drown us in ~50 implicit-any errors before
    // those code paths get extracted into typed modules. The check that
    // really matters here is TS2304 (Cannot find name) — that's what catches
    // "toggleCollapse-is-not-defined" style bugs at build time.
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // The chrome scripting environment exposes a lot of XUL/Mozilla globals.
    // Keep these off until we have ambient .d.ts coverage to match.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/**/*", "build.ts", "build.config.ts"]
}
